---
const projects = [
  {
    title: 'Task Toad',
    subtitle: 'AI-Powered Project Management SaaS',
    description:
      'SaaS tool that turns high-level project goals into shipped code. AI orchestration pipeline decomposes goals into dependency-aware tasks, generates code, creates PRs, runs code review, and monitors CI. Multi-tenant with RBAC, encrypted secrets, and deep GitHub integration.',
    tech: ['React', 'TypeScript', 'GraphQL', 'PostgreSQL', 'Prisma', 'Docker', 'Railway'],
    stats: '69K LOC TypeScript \u00b7 73+ development waves \u00b7 Full security audit',
    link: 'https://tasktoad-api-production.up.railway.app/',
    github: null,
    featured: true,
  },
  {
    title: 'Claude Remote',
    subtitle: 'Mobile Remote Control for Claude Code',
    description:
      'Mobile app to remotely control Claude Code sessions \u2014 start tasks, approve permissions, monitor execution from your phone. Hybrid dashboard + chat mode with context-aware approval cards and push notifications.',
    tech: ['Claude Agent SDK', 'Tailscale', 'React Native', 'WebSocket', 'Push Notifications'],
    link: null,
    github: 'https://github.com/caleblmyers/claude-remote',
    featured: false,
  },
  {
    title: 'Movie Night Picker',
    subtitle: 'Movie Discovery App',
    description:
      'Movie discovery app with a 10-round preference engine, 15+ search filters, collections, ratings/reviews, and person detail pages.',
    tech: ['Next.js 15', 'React 19', 'GraphQL', 'PostgreSQL', 'Prisma', 'NextAuth.js'],
    link: 'https://movie-night-picker-dusky.vercel.app/',
    github: 'https://github.com/caleblmyers/Movie-Night-Picker',
    featured: false,
  },
];

const featured = projects.filter((p) => p.featured);
const other = projects.filter((p) => !p.featured);
---

<section id="projects" class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
  <h2 class="flex items-center gap-3 text-2xl font-bold text-slate-900">
    <span class="font-mono text-sm font-normal text-accent-600">01.</span>
    Projects
    <span class="h-px flex-1 bg-slate-200"></span>
  </h2>

  <!-- Featured project -->
  {featured.map((project) => (
    <div class="mt-12 rounded-xl border border-slate-200 bg-white p-6 shadow-sm sm:p-8">
      <div>
        <div class="flex flex-col justify-center">
          <p class="font-mono text-xs font-medium uppercase tracking-wider text-accent-600">Featured Project</p>
          <h3 class="mt-2 text-2xl font-bold text-slate-900">{project.title}</h3>
          <p class="mt-1 text-sm font-medium text-slate-500">{project.subtitle}</p>
          <p class="mt-4 leading-relaxed text-slate-600">{project.description}</p>
          <p class="mt-3 font-mono text-xs text-slate-500">{project.stats}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {project.tech.map((t) => (
              <span class="rounded-full bg-accent-50 px-3 py-1 text-xs font-medium text-accent-700">
                {t}
              </span>
            ))}
          </div>
          <div class="mt-6 flex items-center gap-4">
            {project.link && (
              <a
                href={project.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-600 hover:text-accent-700"
              >
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
                </svg>
                Live
              </a>
            )}
            {project.github === null && (
              <span class="text-xs text-slate-400">Source available on request</span>
            )}
          </div>
        </div>
      </div>
    </div>
  ))}

  <!-- Other projects -->
  <div class="mt-12 grid gap-6 sm:grid-cols-2">
    {other.map((project) => (
      <div class="group rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
        <h3 class="text-lg font-bold text-slate-900 group-hover:text-accent-600 transition-colors">
          {project.title}
        </h3>
        <p class="mt-0.5 text-sm font-medium text-slate-500">{project.subtitle}</p>
        <p class="mt-3 text-sm leading-relaxed text-slate-600">{project.description}</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {project.tech.map((t) => (
            <span class="rounded-full bg-slate-100 px-2.5 py-0.5 text-xs font-medium text-slate-600">
              {t}
            </span>
          ))}
        </div>
        <div class="mt-4 flex items-center gap-4">
          {project.link && (
            <a
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-accent-600 hover:text-accent-700"
            >
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 0 0 3 8.25v10.5A2.25 2.25 0 0 0 5.25 21h10.5A2.25 2.25 0 0 0 18 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
              </svg>
              Live
            </a>
          )}
          {project.github && (
            <a
              href={project.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-medium text-slate-500 hover:text-slate-700"
            >
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>
