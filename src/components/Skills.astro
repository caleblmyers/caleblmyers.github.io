---
const categories = [
  {
    title: 'Backend',
    skills: ['Node.js', 'Express', 'GraphQL', 'REST APIs', 'PostgreSQL', 'Prisma', 'TypeScript'],
  },
  {
    title: 'Frontend',
    skills: ['React', 'Next.js', 'JavaScript (ES6+)', 'Tailwind CSS', 'Vite'],
  },
  {
    title: 'Cloud & DevOps',
    skills: ['AWS (SA in progress)', 'Docker', 'Git', 'GitHub Actions', 'CI/CD', 'Playwright', 'Vitest', 'S3', 'Railway'],
  },
];
---

<section id="skills" class="mx-auto max-w-5xl px-6 py-20 sm:py-28">
  <h2 class="flex items-center gap-3 text-2xl font-bold text-slate-900">
    <span class="font-mono text-sm font-normal text-accent-600">02.</span>
    Skills
    <span class="h-px flex-1 bg-slate-200"></span>
  </h2>

  <div class="mt-12 grid gap-8 sm:grid-cols-3">
    {categories.map(({ title, skills }) => (
      <div>
        <h3 class="font-mono text-sm font-medium text-accent-600">{title}</h3>
        <ul class="mt-4 space-y-2">
          {skills.map((skill) => (
            <li class="flex items-center gap-2 text-sm text-slate-600">
              <span class="h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent-300"></span>
              {skill}
            </li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</section>
